# Copy to .env and fill in. .env is git-ignored / never committed.

# --- Media generation ------------------------------------------------------
# IMAGES use OpenAI gpt-image-2. Get a key at https://platform.openai.com/api-keys
# (your account may need org verification to access gpt-image-2). LIVE image runs only.
OPENAI_API_KEY=your-openai-key-here

# VIDEO uses Google Veo. Get a key at https://aistudio.google.com/apikey . LIVE video
# runs only. Not needed if you only generate images.
GEMINI_API_KEY=your-gemini-key-here

# Optional: override the model for all video / image rows (beats the sheet's AI
# Model; the --video-model / --image-model CLI flags beat these). Handy to switch
# every video row to a cheaper Veo model without editing the calendar.
# VIDEO_MODEL=veo-3.1-fast-generate-preview
# IMAGE_MODEL=gpt-image-2

# --- Google Drive ----------------------------------------------------------
# Drive folder id of the evergreen "Social Calendar" root (holds the quarter
# subfolders). Required for mock/live upload, generate, and download.
SOCIAL_CALENDAR_ROOT_ID=your-social-calendar-folder-id

# Optional: a separate root for --mock rehearsal uploads, so placeholder files
# never land in (or overwrite) the production quarter folders. If unset, mock
# uploads go to a "_mock rehearsal" subfolder under the quarter.
# SOCIAL_CALENDAR_MOCK_ROOT_ID=your-mock-folder-id

# OAuth "as you" files (Desktop-app client secret + cached token). Defaults to
# credentials.json / token.json next to this file. Authorise once interactively
# before running the server headless (see README).
# GDRIVE_CREDENTIALS_FILE=credentials.json
# GDRIVE_TOKEN_FILE=token.json

# --- Local paths (optional overrides) --------------------------------------
# Where local calendar .xlsx working copies live. Default: this folder.
# CALENDAR_DIR=.
# Scratch dir for generated media before upload. Default: ./generated
# GENERATED_DIR=./generated
